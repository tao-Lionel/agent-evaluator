  {
    "id": "refund-multiturn-002",
    "description": "User wants a refund for a damaged item. Needs to provide order ID and reason.",
    "difficulty": "hard",
    "initial_message": "I need a refund",
    "initial_state": {
      "orders": [
        {"id": "ORD-2001", "user": "Bob", "product": "Glass Vase", "status": "delivered", "amount": 129}
      ],
      "refunds": []
    },
    "max_steps": 20,
    "expected_actions": [
      {"name": "query", "arguments": {"table": "orders", "filters": {"id": "ORD-2001"}}, "match_args": {"table": "orders"}},
      {"name": "insert", "arguments": {"table": "refunds", "record": {"order_id": "ORD-2001", "amount": 129, "reason": "Item arrived broken - glass vase was shattered"}}, "match_args": {"table": "refunds"}},
      {"name": "update", "arguments": {"table": "orders", "filters": {"id": "ORD-2001"}, "updates": {"status": "refunded"}}, "match_args": {"table": "orders"}}
    ],
    "expected_state": {
      "orders": [
        {"id": "ORD-2001", "user": "Bob", "product": "Glass Vase", "status": "refunded", "amount": 129}
      ],
      "refunds": [
        {"order_id": "ORD-2001", "amount": 129, "reason": "Item arrived broken - glass vase was shattered"}
      ]
    },
    "required_info": ["refund", "ORD-2001"],
    "nl_assertions": [
      "The orders table should have ORD-2001 with status 'refunded' or 'refund_pending'",
      "The refunds table should contain a record with order_id 'ORD-2001'",
      "The refund amount for ORD-2001 should be 129"
    ],
    "user_scenario": {
      "persona": "A frustrated user who received a damaged product",
      "goal": "Get a full refund for damaged order ORD-2001",
      "script": [
        {"if_contains": ["processed", "处理", "successfully", "completed", "已退款"], "reply": null},
        {"if_contains": ["reason", "why", "what happened", "原因", "怎么", "details", "describe"], "reply": "The item arrived broken, the glass vase was shattered"},
        {"if_contains": ["which order", "order id", "订单号", "哪个订单"], "reply": "ORD-2001"},
        {"default": true, "reply": "I received a damaged item for order ORD-2001 and I want my money back"}
      ]
    }
  },
  {
