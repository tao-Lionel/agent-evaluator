[
  {
    "id": "cancel-multiturn-001",
    "description": "用户想取消订单，但需要追问才会提供订单号。",
    "difficulty": "medium",
    "initial_message": "我想取消一个订单",
    "initial_state": {
      "orders": [
        {"id": "ORD-1001", "user": "Alice", "product": "蓝牙耳机", "status": "pending", "amount": 299}
      ]
    },
    "max_steps": 15,
    "expected_actions": [
      {"name": "query", "arguments": {"table": "orders", "filters": {"id": "ORD-1001"}}, "match_args": {"table": "orders"}},
      {"name": "update", "arguments": {"table": "orders", "filters": {"id": "ORD-1001"}, "updates": {"status": "cancelled"}}, "match_args": {"table": "orders", "updates": {"status": "cancelled"}}}
    ],
    "expected_state": {
      "orders": [
        {"id": "ORD-1001", "user": "Alice", "product": "蓝牙耳机", "status": "cancelled", "amount": 299}
      ]
    },
    "required_info": ["ORD-1001", "cancelled"],
    "user_scenario": {
      "persona": "一个很忙的用户，不会主动提供全部信息",
      "goal": "取消订单 ORD-1001",
      "script": [
        {"if_contains": ["订单", "order", "哪个", "which"], "reply": "ORD-1001"},
        {"if_contains": ["已取消", "cancelled", "成功", "success"], "reply": null},
        {"default": true, "reply": "我就是想取消订单，帮我处理一下"}
      ]
    }
  },
  {
    "id": "refund-multiturn-002",
    "description": "用户想退款，需要提供订单号和退款原因。",
    "difficulty": "hard",
    "initial_message": "我要退款",
    "initial_state": {
      "orders": [
        {"id": "ORD-2001", "user": "Bob", "product": "玻璃花瓶", "status": "delivered", "amount": 129}
      ],
      "refunds": []
    },
    "max_steps": 20,
    "expected_actions": [
      {"name": "query", "arguments": {"table": "orders", "filters": {"id": "ORD-2001"}}, "match_args": {"table": "orders"}},
      {"name": "insert", "arguments": {"table": "refunds", "record": {"order_id": "ORD-2001", "amount": 129, "reason": "收到的花瓶碎了"}}, "match_args": {"table": "refunds"}},
      {"name": "update", "arguments": {"table": "orders", "filters": {"id": "ORD-2001"}, "updates": {"status": "refunded"}}, "match_args": {"table": "orders"}}
    ],
    "expected_state": {
      "orders": [
        {"id": "ORD-2001", "user": "Bob", "product": "玻璃花瓶", "status": "refunded", "amount": 129}
      ],
      "refunds": [
        {"order_id": "ORD-2001", "amount": 129}
      ]
    },
    "required_info": ["退款", "ORD-2001"],
    "nl_assertions": [
      "orders 表中 ORD-2001 的 status 应为 refunded 或 refund_pending",
      "refunds 表中应包含 order_id 为 ORD-2001 的记录",
      "ORD-2001 的退款金额应为 129"
    ],
    "user_scenario": {
      "persona": "一个收到损坏商品的愤怒用户",
      "goal": "为损坏的订单 ORD-2001 申请全额退款",
      "script": [
        {"if_contains": ["已处理", "processed", "成功", "completed", "已退款"], "reply": null},
        {"if_contains": ["原因", "reason", "怎么了", "什么问题", "详细"], "reply": "收到的花瓶碎了，整个都裂开了"},
        {"if_contains": ["哪个订单", "订单号", "order id", "which order"], "reply": "ORD-2001"},
        {"default": true, "reply": "我收到的东西是坏的，订单号 ORD-2001，我要退款"}
      ]
    }
  },
  {
    "id": "address-change-multiturn-003",
    "description": "用户想修改收货地址，分步提供订单号和新地址。",
    "difficulty": "medium",
    "initial_message": "我要改一下收货地址",
    "initial_state": {
      "orders": [
        {"id": "ORD-3001", "user": "Carol", "product": "台灯", "status": "pending", "amount": 89, "address": "旧街100号"}
      ]
    },
    "max_steps": 15,
    "expected_actions": [
      {"name": "query", "arguments": {"table": "orders", "filters": {"id": "ORD-3001"}}, "match_args": {"table": "orders"}},
      {"name": "update", "arguments": {"table": "orders", "filters": {"id": "ORD-3001"}, "updates": {"address": "新大道200号"}}, "match_args": {"table": "orders", "updates": {"address": "新大道200号"}}}
    ],
    "expected_state": {
      "orders": [
        {"id": "ORD-3001", "user": "Carol", "product": "台灯", "status": "pending", "amount": 89, "address": "新大道200号"}
      ]
    },
    "required_info": ["新大道200号"],
    "user_scenario": {
      "persona": "一个搬了新家的礼貌用户",
      "goal": "把订单 ORD-3001 的收货地址改为新大道200号",
      "script": [
        {"if_contains": ["已更新", "已修改", "updated", "changed", "成功"], "reply": null},
        {"if_contains": ["新地址", "new address", "改成什么", "什么地址"], "reply": "新大道200号"},
        {"if_contains": ["哪个订单", "订单号", "order id", "which order"], "reply": "ORD-3001"},
        {"default": true, "reply": "我要改收货地址，订单号是 ORD-3001"}
      ]
    }
  }
